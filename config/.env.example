# === Sports ===
# Supports wildcard groups:
# - soccer_all (or soccer_*) => all available soccer leagues from The Odds API
# - tennis_all (or tennis_*) => all available tennis leagues from The Odds API
# - cricket_all (or cricket_*) => all available cricket leagues from The Odds API
# - rugby_all (or rugby_*) => all available rugby leagues from The Odds API
# - table_tennis_all (or table_tennis_*) => all available table tennis leagues from The Odds API
# Supports family aliases (auto-resolve active keys year-round):
# - tennis_atp -> tennis_atp_* currently active tournaments
# - tennis_wta -> tennis_wta_* currently active tournaments
# - cricket -> cricket_* currently active tournaments/leagues
# - rugby -> rugby_* currently active tournaments/leagues
# - table_tennis -> table_tennis_* currently active tournaments/leagues
SPORTS=basketball_nba,americanfootball_nfl,baseball_mlb,icehockey_nhl,soccer_epl,tennis_atp,tennis_wta,cricket,rugby,table_tennis

# === Dashboard ===
DASHBOARD_PORT=8502
DASHBOARD_PASSWORD=
DASHBOARD_ALLOW_NO_PASSWORD=1
